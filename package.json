{
  "name": "kennook",
  "version": "0.1.0",
  "private": true,
  "description": "Your personal media library, smarter.",
  "scripts": {
    "dev": "tsx scripts/dev-banner.ts && next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "build:prod": "KENNOOK_PROD=1 next build",
    "start:prod": "KENNOOK_PROD=1 next start -H 0.0.0.0 -p 3001",
    "prod": "pnpm build:prod && pnpm start:prod",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "indexer": "tsx src/indexer/index.ts",
    "backfill:vectors": "tsx src/indexer/backfill-embeddings.ts",
    "backfill:previews": "tsx src/indexer/backfill-previews.ts",
    "backfill:views": "tsx src/indexer/backfill-views.ts",
    "backfill:all": "tsx src/indexer/run-sequence.ts backfill:vectors,backfill:previews,backfill:views",
    "enrich:text": "tsx src/indexer/enrich.ts",
    "enrich:faces": "tsx src/indexer/face-enrich.ts",
    "enrich:people": "tsx src/indexer/cluster-faces.ts",
    "enrich:sensitive": "tsx src/indexer/sensitive-enrich.ts",
    "enrich:video-text": "tsx src/indexer/enrich-video-text.ts",
    "enrich:transcript": "tsx src/indexer/enrich-transcript.ts",
    "enrich:transcript-tags": "tsx src/indexer/enrich-transcript-tags.ts",
    "enrich:watch": "tsx src/indexer/enrich-watch.ts",
    "enrich:all": "tsx src/indexer/run-sequence.ts enrich:text,enrich:video-text,enrich:transcript,enrich:transcript-tags,enrich:faces,enrich:sensitive,enrich:people",
    "setup": "tsx src/indexer/run-sequence.ts indexer,backfill:all,enrich:all",
    "migrate-libraries": "tsx src/indexer/migrate-to-libraries.ts",
    "storage": "tsx src/indexer/manage-storage.ts",
    "extract-storages": "tsx src/indexer/extract-storages.ts",
    "cleanup-default-storages": "tsx src/indexer/cleanup-default-storages.ts",
    "reset": "tsx src/indexer/reset.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.0.0",
    "@tanstack/react-query": "^5.59.0",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@trpc/client": "^11.0.0-rc.660",
    "@trpc/next": "^11.0.0-rc.660",
    "@trpc/react-query": "^11.0.0-rc.660",
    "@trpc/server": "^11.0.0-rc.660",
    "@vladmandic/face-api": "^1.7.15",
    "compromise": "^14.15.0",
    "drizzle-orm": "^0.36.0",
    "exifr": "^7.1.3",
    "next": "^15.0.0",
    "nsfwjs": "^4.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.0",
    "sqlite-vec": "^0.1.6",
    "superjson": "^2.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
